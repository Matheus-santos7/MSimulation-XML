# =============================================================================
# MSimulation-XML — Next.js (frontend)
# =============================================================================
#
# Uso (opcional em desenvolvimento local):
#   cp .env.example .env.local
#
# O Next.js carrega .env.local automaticamente. Sem este arquivo, a URL da API
# padrão é http://127.0.0.1:3001 (mesma porta do backend em pnpm dev).
# =============================================================================

# --- API backend (opcional) ----------------------------------------------------
# URL pública da API Fastify. Deve ser acessível pelo browser (CORS já permite localhost).

NEXT_PUBLIC_API_URL=http://127.0.0.1:3001
