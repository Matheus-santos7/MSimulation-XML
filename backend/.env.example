# =============================================================================
# MSimulation-XML — API Fastify + Prisma
# =============================================================================
#
# Uso:
#   cp .env.example .env
#   # Na raiz do monorepo:
#   cp .env.example .env          # Docker (POSTGRES_*)
#   pnpm docker:up && pnpm db:setup
#   pnpm dev
#
# O dotenv carrega este arquivo a partir da pasta backend/ (cwd do pacote).
# =============================================================================

# --- Banco de dados (obrigatório) ----------------------------------------------

# Com Docker: use o mesmo usuário/senha/db de ../.env (POSTGRES_*)
DATABASE_URL=postgresql://msimulation:msimulation@localhost:5432/msimulation_xml?schema=public

# Render (dev local apontando para produção): use a External Database URL do dashboard
# (hostname termina em .REGION-postgres.render.com) e inclua SSL + schema:
# DATABASE_URL=postgresql://USER:PASS@dpg-xxxxx-a.virginia-postgres.render.com:5432/DB?schema=public&sslmode=require

# --- Servidor HTTP (opcional — padrões: PORT=3001, HOST=0.0.0.0) -------------

PORT=3001
HOST=0.0.0.0

# --- CORS (obrigatório em produção) --------------------------------------------
# Origens permitidas do frontend, separadas por vírgula.
# Dev sem valor: apenas http://localhost:* e http://127.0.0.1:*

CORS_ORIGINS=http://localhost:3000

# --- Autenticação JWT (obrigatório) --------------------------------------------
# JWT_SECRET: mín. 16 caracteres (dev) / 32 (produção). Gere com: openssl rand -base64 32

JWT_SECRET=change-me-use-long-random-secret-in-production-min-32-chars
JWT_ACCESS_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=7d

# --- Segurança de senha (obrigatório em produção) ------------------------------
# PASSWORD_PEPPER: mín. 16 caracteres. Valor distinto do JWT_SECRET.

PASSWORD_PEPPER=defina-um-segredo-aleatorio-longo-aqui

# --- Frontend público (recomendado) --------------------------------------------
# Links em e-mails (reset de senha). Alternativa: FRONTEND_URL

APP_PUBLIC_URL=http://localhost:3000
# FRONTEND_URL=http://localhost:3000

# --- Reset de senha (opcional) -------------------------------------------------

PASSWORD_RESET_EXPIRES_IN=1h

# --- E-mail — Resend (opcional em dev / obrigatório em produção) ---------------
# https://resend.com/api-keys
# Sem RESEND_API_KEY em dev, o link de reset é impresso no console da API.

RESEND_API_KEY=
# Sandbox Resend: só entrega para o e-mail da conta em onboarding@resend.dev
# Produção: verifique seu domínio em https://resend.com/domains e use noreply@seudominio.com
RESEND_FROM_EMAIL=MSimulation XML <onboarding@resend.dev>MSimulation XML <onboarding@resend.dev>

# --- Proteção de login (opcional) ----------------------------------------------

LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# --- 2FA (opcional) ------------------------------------------------------------

TWO_FACTOR_PENDING_EXPIRES_IN=5m

# --- CAPTCHA Cloudflare Turnstile (recomendado em produção) -------------------
# https://dash.cloudflare.com/?to=/:account/turnstile
# Em dev sem chaves, o CAPTCHA é ignorado no backend.

TURNSTILE_SECRET_KEY=

# --- Verificação de e-mail (opcional) ------------------------------------------
# Pré-lançamento: false (cadastro sem confirmação). Go-live: true + domínio Resend.

REQUIRE_EMAIL_VERIFICATION=false
EMAIL_VERIFICATION_EXPIRES_IN=24h

# --- Proxy / deploy (produção atrás de reverse proxy) --------------------------

TRUST_PROXY=true
