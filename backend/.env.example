# Copie para backend/.env
# cp .env.example .env
#
# Com Docker (pnpm docker:up), use a URL abaixo.
# Sem Docker, ajuste host, usuário e senha.

DATABASE_URL="postgresql://msedit:msedit@localhost:5432/msedit_xml?schema=public"
PORT=3001
HOST=0.0.0.0

# JWT — access token curto (mín. 16 dev / 32 produção)
JWT_SECRET="change-me-use-long-random-secret-in-production-min-32-chars"
JWT_ACCESS_EXPIRES_IN="30m"
JWT_REFRESH_EXPIRES_IN="7d"

# Pepper para hash de senha e refresh token (mín. 16 caracteres; obrigatório em produção)
PASSWORD_PEPPER="defina-um-segredo-aleatorio-longo-aqui"

# URL pública do frontend (links no e-mail de reset)
APP_PUBLIC_URL="http://localhost:3000"
PASSWORD_RESET_EXPIRES_IN="1h"

# Resend — https://resend.com/api-keys (em dev, sem chave o link é logado no console)
RESEND_API_KEY=""
# Domínio verificado no Resend; sandbox: onboarding@resend.dev (só entrega no e-mail da conta Resend)
RESEND_FROM_EMAIL="MSimulation XML <onboarding@resend.dev>"

# Bloqueio após tentativas de login falhas
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Token pendente de 2FA (após senha correta)
TWO_FACTOR_PENDING_EXPIRES_IN=5m
