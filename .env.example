# =============================================================================
# MSimulation-XML — variáveis da raiz (Docker Compose)
# =============================================================================
#
# Uso:
#   cp .env.example .env
#   pnpm docker:up
#
# Este arquivo é lido pelo `docker compose` para subir o PostgreSQL local.
# Segredos de API (JWT, e-mail, etc.) ficam em backend/.env — não coloque aqui.
#
# Documentação completa: backend/.env.example e frontend/.env.example
# =============================================================================

# --- PostgreSQL (container) — obrigatório para `pnpm docker:up` ---------------

POSTGRES_USER=msimulation
POSTGRES_PASSWORD=msimulation
POSTGRES_DB=msimulation_xml
POSTGRES_PORT=5432

# --- Referência (opcional) -----------------------------------------------------
# A API e o Prisma usam DATABASE_URL em backend/.env, não neste arquivo.
# Mantenha os valores abaixo alinhados com POSTGRES_* ao copiar para o backend.
#
# DATABASE_URL=postgresql://msimulation:msimulation@localhost:5432/msimulation_xml?schema=public
